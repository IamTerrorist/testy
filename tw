local function getInventoryCounts()
    local owned = {}
    local function countTool(tool)
        if not tool:IsA("Tool") then return end
        local stack    = 1
        local amountVal = tool:FindFirstChild("Amount") or tool:FindFirstChild("Stack") or tool:FindFirstChild("Count")
        if amountVal and amountVal:IsA("IntValue") then stack = amountVal.Value end
        owned[tool.Name] = (owned[tool.Name] or 0) + stack
    end
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local char     = LocalPlayer.Character
    if backpack then for _, tool in pairs(backpack:GetChildren()) do countTool(tool) end end
    if char     then for _, tool in pairs(char:GetChildren())    do countTool(tool) end end
    return owned
end

local function getMissingBlockTypes(blocks)
    local inventory = getInventoryCounts()
    local needed = {}
    for _, block in ipairs(blocks) do
        needed[block.blockType] = (needed[block.blockType] or 0) + 1
    end
    local missing = {}
    for name, totalNeeded in pairs(needed) do
        local shortfall = totalNeeded - (inventory[name] or 0)
        if shortfall > 0 then
            table.insert(missing, { name = name, count = shortfall })
        end
    end
    table.sort(missing, function(a, b) return a.name < b.name end)
    return missing
end

