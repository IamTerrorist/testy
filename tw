    local function findResizeSectionFrame()
        local roots = { CoreGui, LocalPlayer.PlayerGui }
        for _, root in ipairs(roots) do
            for _, desc in ipairs(root:GetDescendants()) do
                if desc:IsA("TextLabel") and desc.Text and desc.Text:find("Resize Tool") then
                    return desc.Parent -- the section frame itself
                end
            end
        end
        return nil
    end

    local sectionFrame = findResizeSectionFrame()
    if not sectionFrame then return end

    -- Insert the animated label as a sibling just before the section frame
    local container = sectionFrame.Parent
    if not container then return end

    local lbl = Instance.new("TextLabel")
    lbl.Size               = UDim2.new(1, 0, 0, 28)
    lbl.BackgroundTransparency = 1
    lbl.TextColor3         = Color3.fromRGB(255, 220, 80)
    lbl.TextSize           = 18
