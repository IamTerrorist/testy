-- Populate blockNames from ReplicatedStorage.Tools in background
local function buildBlockNames()
    local toolsFolder = ReplicatedStorage:WaitForChild("Tools", 10)
    if not toolsFolder then return end
    local deadline = tick() + 5
    while #toolsFolder:GetChildren() == 0 and tick() < deadline do
        task.wait(0.1)
    end
    for _, tool in pairs(toolsFolder:GetChildren()) do
        local dn = tool:FindFirstChild("DisplayName")
        if dn and dn:IsA("StringValue") and dn.Value ~= "" then
            blockNames[tool.Name] = dn.Value
        end
    end
end
