local function roundToStep(n, step)
    return math.floor((n / step) + 0.5) * step
end

local function vectorKey(v)
    return table.concat({
        tostring(roundToStep(v.X, rounding)),
        tostring(roundToStep(v.Y, rounding)),
        tostring(roundToStep(v.Z, rounding))
    }, "|")
end

local function makeBlockKey(blockType, cf)
    return tostring(blockType) .. "@" .. vectorKey(cf.Position)
end

local function arrayToCFrame(a)
    local pos   = Vector3.new(a[1], a[2], a[3])
    local right = Vector3.new(a[4], a[5], a[6])
    local up    = Vector3.new(a[7], a[8], a[9])
    return CFrame.fromMatrix(pos, right, up)
end

local function cframeToArray(cf)
    local pos   = cf.Position
    local right = cf.RightVector
    local up    = cf.UpVector
    return {
        pos.X,   pos.Y,   pos.Z,
        right.X, right.Y, right.Z,
        up.X,    up.Y,    up.Z
    }
end

local function getFiles()
    local files = {}
    for _, file in ipairs(listfiles("autoBuilder")) do
        local lower = string.lower(file)
        if lower:sub(-4) == ".txt" or lower:sub(-5) == ".json" then
            -- Skip empty files (executor fallback blanks file instead of deleting)
            local ok, data = pcall(readfile, file)
            if ok and data and #data > 0 then
                table.insert(files, file:match("[^/\\]+$"))
            end
        end
    end
    table.sort(files)
    return files
end

local function getNearestIsland()
    local islandsFolder = Workspace:FindFirstChild("Islands")
    if not islandsFolder then return nil end
    local _, _, hrp = getCharacterParts()
    if not hrp then return nil end
    local closestIsland, closestDistance = nil, math.huge
    for _, child in ipairs(islandsFolder:GetChildren()) do
        if child:IsA("Model") then
            local dist = (child:GetPivot().Position - hrp.Position).Magnitude
            if dist < closestDistance then
                closestDistance = dist
                closestIsland   = child
            end
        end
    end
    return closestIsland
end

local function getBlocksFolder()
    local island = getNearestIsland()
    return island and island:FindFirstChild("Blocks")
end

local function buildExistingBlockMap()
    local blocksFolder = getBlocksFolder()
    if not blocksFolder then return {} end
    local existingMap = {}
    local blocks = blocksFolder:GetChildren()
    for i = 1, #blocks do
        local block = blocks[i]
        if block:IsA("BasePart") and block.Name ~= "portalToSpawn" and block.Name ~= "bedrock" then
            existingMap[makeBlockKey(block.Name, block.CFrame)] = true
        end
        if i % 5000 == 0 then task.wait() end
    end
    return existingMap
end

local function getPlacedAndMissingBlocks(targetBlocks)
    local existingMap = buildExistingBlockMap()
    local placed, missing = {}, {}
    for i, block in ipairs(targetBlocks) do
        local cf  = arrayToCFrame(block.cframe)
        local key = makeBlockKey(block.blockType, cf)
        if existingMap[key] then table.insert(placed, block)
        else table.insert(missing, block) end
        if i % 5000 == 0 then task.wait() end
    end
    return placed, missing
end

local function getMissingBlocks(targetBlocks)
    local _, missing = getPlacedAndMissingBlocks(targetBlocks)
    return missing
end

local function placeRawBlock(blockType, cf, upperBlock)
    local n = getNet()
    if not n then return false end
    local args = {{
        uwhiHAMdjExWka = "\a\240\159\164\163\240\159\164\161\a\n\a\n\a\nffEgdldU",
        cframe         = cf,
        blockType      = blockType,
        upperBlock     = upperBlock == true
    }}
    local ok, err = pcall(function() n:InvokeServer(unpack(args)) end)
    if not ok then warn("Place failed:", blockType, err) end
    return ok
end

local function blockExists(block)
    local blocksFolder = getBlocksFolder()
    if not blocksFolder then return false end
    local cf  = arrayToCFrame(block.cframe)
    local key = makeBlockKey(block.blockType, cf)
    for _, part in ipairs(blocksFolder:GetChildren()) do
        if part:IsA("BasePart") and part.Name == block.blockType then
            if makeBlockKey(part.Name, part.CFrame) == key then return true end
        end
    end
    return false
end

local function getAdaptiveWalkTarget(targetPos, hrpPos)
    local dir = hrpPos - targetPos
    if dir.Magnitude < 0.01 then dir = Vector3.new(0,0,-1) else dir = dir.Unit end
    local yDelta = targetPos.Y - hrpPos.Y
    return targetPos + (dir * walkOffset) + Vector3.new(0, math.clamp(yDelta+2, -8, 18), 0)
end

local function moveToPoint(point)
    local _, humanoid = getCharacterParts()
    if not humanoid then return false end
    humanoid:MoveTo(point)
    local reached, conn = false, nil
    conn = humanoid.MoveToFinished:Connect(function() reached = true end)
    local start = tick()
    while not reached and (tick()-start) < waypointTimeout do
        task.wait(0.05)
        if not isBuilding then break end
    end
    if conn then conn:Disconnect() end
    return reached
end

local function pathfindWalkTo(targetPoint)
    local _, humanoid, hrp = getCharacterParts()
    if not humanoid or not hrp then return false end
    local path = PathfindingService:CreatePath({
        AgentRadius=2, AgentHeight=5, AgentCanJump=true, AgentCanClimb=true, WaypointSpacing=4
    })
    local success = pcall(function() path:ComputeAsync(hrp.Position, targetPoint) end)
    if not success or path.Status ~= Enum.PathStatus.Success then
        pressShift() moveToPoint(targetPoint) releaseShift() return true
    end
    pressShift()
    for _, wp in ipairs(path:GetWaypoints()) do
        if not isBuilding then break end
        if wp.Action == Enum.PathWaypointAction.Jump then humanoid.Jump = true end
        moveToPoint(wp.Position)
    end
    releaseShift()
    return true
end

local floatHeightThreshold = 10

local function moveNearBlock(block)
    if not moveToBuildPosition then return end
    local _, humanoid, hrp = getCharacterParts()
    if not hrp then return end
    local targetPos = arrayToCFrame(block.cframe).Position
    if (hrp.Position - targetPos).Magnitude <= movementThreshold then return end
    local heightDiff = targetPos.Y - hrp.Position.Y
    if heightDiff > floatHeightThreshold then
        if not floating then enableFloat() end
        local tweenInfo = TweenInfo.new(
            math.clamp((hrp.Position - targetPos).Magnitude / 60, 0.3, 4),
            Enum.EasingStyle.Linear
        )
        local tween = TweenService:Create(hrp, tweenInfo, { CFrame = CFrame.new(targetPos + Vector3.new(0, 5, 0)) })
        tween:Play()
        local start = tick()
        repeat
            task.wait(0.05)
            if not isBuilding then tween:Cancel() return end
        until (hrp.Position - targetPos).Magnitude <= movementThreshold or (tick() - start) > 6
        tween:Cancel()
    else
        pathfindWalkTo(getAdaptiveWalkTarget(targetPos, hrp.Position))
    end
end

local function placeBlock(block)
    moveNearBlock(block)
    return placeRawBlock(block.blockType, arrayToCFrame(block.cframe), block.upperBlock == true)
end


-- Sort blocks bottom-to-top by Y layer, then sweep XZ so movement is minimal
-- Pre-cache block positions so we don't call arrayToCFrame repeatedly
local function cacheBlockPositions(blocks)
    local cache = {}
    for i, block in ipairs(blocks) do
        cache[i] = arrayToCFrame(block.cframe).Position
    end
    return cache
end

-- Simple bottom-to-top sort only — no greedy sweep
-- The player will naturally be near the block they just placed,
-- so placing in Y-layer order is enough without expensive nearest-neighbour
local function sortBlocksForBuild(blocks)
    local withPos = {}
    for _, block in ipairs(blocks) do
        local pos = arrayToCFrame(block.cframe).Position
        table.insert(withPos, { block = block, pos = pos })
    end
    -- Sort bottom to top, then left to right (X), then front to back (Z)
    -- This creates a predictable sweep pattern so movement is minimal
    table.sort(withPos, function(a, b)
        if a.pos.Y ~= b.pos.Y then return a.pos.Y < b.pos.Y end
        if a.pos.X ~= b.pos.X then return a.pos.X < b.pos.X end
        return a.pos.Z < b.pos.Z
    end)
    local sorted = {}
    for _, entry in ipairs(withPos) do
        table.insert(sorted, entry.block)
    end
    return sorted
end


local function placeBlockList(blockList, delayTime)
    local failed = {}
    if #blockList == 0 then return failed end

    -- Shared queue — all threads pull from the same list
    -- So when a fast type finishes its own blocks it steals from the remaining queue
    local queue   = {}
    local qHead   = 1  -- index of next block to place
    local qSize   = #blockList
    local qLock   = false  -- spin lock for queue head

    -- Sort first so blocks are in optimal order
    local sorted = sortBlocksForBuild(blockList)
    for _, b in ipairs(sorted) do table.insert(queue, b) end

    -- Count unique types to decide thread count
    local typeSet = {}
    for _, b in ipairs(blockList) do typeSet[b.blockType] = true end
    local threadCount = 0
    for _ in pairs(typeSet) do threadCount = threadCount + 1 end
    threadCount = math.max(1, threadCount)

    local activeThreads = threadCount

    local function getNextBlock()
        -- Simple atomic increment via spin
        while qLock do task.wait() end
        qLock = true
        local idx = qHead
        qHead = qHead + 1
        qLock = false
        if idx <= qSize then return queue[idx] end
        return nil
    end

    for _ = 1, threadCount do
        task.spawn(function()
            while isBuilding do
                local block = getNextBlock()
                if not block then break end
                if moveToBuildPosition then moveNearBlock(block) end
                if not isBuilding then break end
                placeRawBlock(block.blockType, arrayToCFrame(block.cframe), block.upperBlock == true)
            end
            activeThreads = activeThreads - 1
        end)
    end

    while activeThreads > 0 and isBuilding do
        task.wait()
    end

    return failed
end


-- Converts internal block IDs to readable display names
-- e.g. "1bed" -> "Tier 1 Bed", "vendingMachine1" -> "Vending Machine 1"
local function getDisplayName(internalName)
    local name = internalName

    -- Handle leading number prefix: "1bed" -> "Tier 1 Bed"
    local tier, rest = name:match("^(%d+)(.+)")
    if tier and rest then
        name = "Tier " .. tier .. " " .. rest
    end

    -- Split camelCase: "vendingMachine" -> "Vending Machine"
    name = name:gsub("(%l)(%u)", function(a, b) return a .. " " .. b end)
    name = name:gsub("(%u+)(%u%l)", function(a, b) return a .. " " .. b end)

    -- Split trailing digits: "Machine1" -> "Machine 1"
    name = name:gsub("(%a)(%d)", function(a, b) return a .. " " .. b end)

    -- Capitalise first letter of each word
    name = name:gsub("(%a)([%w_']*)", function(first, r)
        return first:upper() .. r
    end)

    -- Fix known special cases
    name = name:gsub("^Atm ", "ATM ")
    name = name:gsub(" Io$", " I/O")
    name = name:gsub(" Io ", " I/O ")

    return name
end

