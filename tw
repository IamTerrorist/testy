-- Safely move a file to autoBuilderTrash/
local function tryMoveToTrash(fname)
    local src   = "autoBuilder/"      .. fname
    local trash = "autoBuilderTrash/" .. fname
    if not isfile(src) then return false, "file not found" end
    local ok, err = pcall(function() writefile(trash, readfile(src)) end)
    if not ok then return false, tostring(err) end
    -- Try executor delete APIs
    for _, fn in ipairs({"delfile", "removefile"}) do
        local fnRef
        pcall(function() fnRef = getfenv(0)[fn] end)
        if type(fnRef) == "function" and pcall(fnRef, src) then return true end
    end
    -- Fallback: blank the file so it appears empty
    pcall(writefile, src, "")
    return true
end

