        nameBtn.MouseButton1Click:Connect(function()
            loadFileSelected = captureFname
            sg:Destroy()
            fileListGui = nil
        end)

        -- Trash button — 2 clicks: first = confirm (turns orange), second = move to trash
        local trashBtn = Instance.new("TextButton")
        trashBtn.Size            = UDim2.fromOffset(38, ROW_H - 10)
        trashBtn.Position        = UDim2.new(1, -46, 0.5, -((ROW_H-10)/2))
        trashBtn.BackgroundColor3 = Color3.fromRGB(140, 30, 30)
        trashBtn.Text            = "X"
        trashBtn.TextColor3      = Color3.fromRGB(255, 255, 255)
        trashBtn.TextSize        = 13
        trashBtn.Font            = Enum.Font.GothamBold
        trashBtn.BorderSizePixel = 0
        trashBtn.ZIndex          = 3
        trashBtn.Parent          = row
        Instance.new("UICorner", trashBtn).CornerRadius = UDim.new(0, 5)

        -- Per-button local state — no shared globals, no conflicts
        local confirmPending = false
        local confirmConn    = nil

        trashBtn.MouseButton1Click:Connect(function()
            if confirmPending then
                -- 2nd click — delete
                confirmPending = false
                if confirmConn then confirmConn:Disconnect() confirmConn = nil end
                local ok, err = tryMoveToTrash(captureFname)
                if ok then
                    if loadFileSelected == captureFname then loadFileSelected = nil end
                    deletedFiles[captureFname] = true
                    if loadFileSelected == captureFname then loadFileSelected = nil end
                    -- Close the menu immediately — file is gone from sight right now
                    if fileListGui then fileListGui:Destroy() fileListGui = nil end
                    notify("Moved to Trash", captureFname.." moved to autoBuilderTrash/", 3)
                    task.spawn(function()
                        task.wait(2)
                    end)
                else
                    notify("Error", "Could not delete: "..tostring(err), 4)
                    pcall(function()
                        trashBtn.Text             = "X"
                        trashBtn.BackgroundColor3 = Color3.fromRGB(140, 30, 30)
                    end)
                end
            else
                -- 1st click — enter confirm mode
                confirmPending            = true
                trashBtn.Text             = "?"
                trashBtn.BackgroundColor3 = Color3.fromRGB(210, 75, 15)
                -- Auto-reset after 3 seconds using Heartbeat (reliable)
                local elapsed = 0
                confirmConn = RunService.Heartbeat:Connect(function(dt)
                    elapsed = elapsed + dt
                    if elapsed >= 3 then
                        confirmPending = false
                        confirmConn:Disconnect()
                        confirmConn = nil
                        pcall(function()
                            trashBtn.Text             = "X"
                            trashBtn.BackgroundColor3 = Color3.fromRGB(140, 30, 30)
                        end)
                    end
                end)
            end
        end)
    end
end

