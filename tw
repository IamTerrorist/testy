-- Noclip — defined here so runBuild can call setNoclip automatically
local noclipEnabled = false
local noclipConn    = nil

local function setNoclip(enabled)
    noclipEnabled = enabled
    if enabled then
        if noclipConn then noclipConn:Disconnect() end
        noclipConn = RunService.Stepped:Connect(function()
            local char = LocalPlayer.Character
            if not char then return end
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") and part.Name ~= floatPartName then
                    part.CanCollide = false
                end
            end
        end)
    else
        if noclipConn then
            noclipConn:Disconnect()
            noclipConn = nil
        end
        local char = LocalPlayer.Character
        if char then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then hrp.CanCollide = true end
        end
    end
end

local function runBuild(blocks, missingOnly)
    if isBuilding then notify("Busy", "Builder is already running", 3) return end
    isBuilding = true
    task.spawn(function()
        -- Disable collision on character parts (except float platform)
        local _char = LocalPlayer.Character
        if _char then
            for _, part in pairs(_char:GetDescendants()) do
                if part:IsA("BasePart") and part.Name ~= floatPartName then
                    part.CanCollide = false
                end
            end
        end
        if missingOnly then
            notify("Scanning", "Checking placed and missing blocks...", 4)
            local placed, missing = getPlacedAndMissingBlocks(blocks)
            notify("Scan Complete", "Placed: "..#placed.." | Missing: "..#missing, 5)
            if #missing == 0 then isBuilding = false notify("Nothing Missing", "All blocks are already placed", 4) return end
            local pass, currentMissing = 1, missing
            while isBuilding and #currentMissing > 0 do
                notify("Missing Block Pass", "Pass "..pass..": placing "..#currentMissing.." blocks", 4)
                local failed = placeBlockList(sortBlocksForBuild(currentMissing), placeDelay)
                task.wait(verifyWaitTime)
                currentMissing = getMissingBlocks(blocks)
                pass += 1
                if #failed > 0 and #failed == #currentMissing and pass >= 4 then break end
            end
            isBuilding = false
            local finalMissing = getMissingBlocks(blocks)
            if #finalMissing == 0 then notify("Done", "All missing blocks have been placed", 5)
            else notify("Finished With Skips", "Still missing "..#finalMissing.." block(s)", 6) end
        else
            local sortedBlocks = sortBlocksForBuild(blocks)
            notify("Building Started", "Placing "..#sortedBlocks.." blocks (sorted)", 4)
            local failed = placeBlockList(sortedBlocks, placeDelay)
            task.wait(verifyWaitTime)
            local missing = getMissingBlocks(blocks)
            local pass = 1
            while isBuilding and #missing > 0 do
                notify("Retry Pass", "Pass "..pass..": retrying "..#missing.." missing blocks", 4)
                failed = placeBlockList(sortBlocksForBuild(missing), retryDelay)
                task.wait(verifyWaitTime)
                local newMissing = getMissingBlocks(blocks)
                if #newMissing == #missing and pass >= 4 then missing = newMissing break end
                missing = newMissing
                pass += 1
            end
            isBuilding = false
            if #missing == 0 then notify("Build Complete", "All blocks placed successfully", 5)
            else notify("Finished With Skips", "Could not place "..#missing.." block(s)", 6) end
        end
        releaseShift()
    end)
end

local function runBuildWithCheck(blocks, missingOnly)
    local missingTypes = getMissingBlockTypes(blocks)
    if #missingTypes > 0 then
        showMissingPopup(missingTypes, function()
            task.spawn(function() runBuild(blocks, missingOnly) end)
        end)
    else
        task.spawn(function() runBuild(blocks, missingOnly) end)
    end
end

