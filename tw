    lbl.TextXAlignment     = Enum.TextXAlignment.Center
    lbl.Text               = "PGTRD"
    lbl.ZIndex             = sectionFrame.ZIndex
    lbl.Parent             = container

    -- Push it just above the section frame using LayoutOrder if a UIListLayout is present
    local layout = container:FindFirstChildOfClass("UIListLayout")
    if layout then
        lbl.LayoutOrder = sectionFrame.LayoutOrder - 1
    else
        lbl.Position = UDim2.new(sectionFrame.Position.X.Scale, sectionFrame.Position.X.Offset, 0, sectionFrame.Position.Y.Offset - 30)
    end

    -- Animate: PGTRD -> PGTR -> PGT -> PG -> P -> PGTRD ...
    local frames = { "PGTRD", "PGTR", "PGT", "PG", "P", "PGTRD" }
    local i = 1
    while lbl and lbl.Parent do
        lbl.Text = frames[i]
        i = (i % #frames) + 1
        task.wait(0.3)
    end
end)

