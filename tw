        if not loadFileSelected or loadFileSelected == "" then
            notify("No File Selected", "Pick a file from Select File to Load first.", 3) return
        end
        local path = "autoBuilder/" .. loadFileSelected
        if not isfile(path) then notify("Error", "File not found: "..tostring(loadFileSelected), 4) return end
