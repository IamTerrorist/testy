-- Tracks which block types the user has chosen to skip (remove from build)
local removedTypes = {}

-- Updates ghost block colours — removed types go red, active ones go normal blue
local function updateGhostColors()
    if not CloneFolder then return end
    for _, b in pairs(CloneFolder:GetChildren()) do
        if (b:IsA("Part") or b:IsA("MeshPart")) and b.Name ~= "PrimaryPart" then
            if removedTypes[b.Name] then
                b.Color         = Color3.fromRGB(200, 40, 40)
                b.Transparency  = 0.4
                -- Add / refresh a BillboardGui X marker
                local bb = b:FindFirstChild("RemovedMarker")
                if not bb then
                    bb = Instance.new("BillboardGui")
                    bb.Name          = "RemovedMarker"
                    bb.Size          = UDim2.fromOffset(40, 40)
                    bb.AlwaysOnTop   = true
                    bb.Parent        = b
                    local lbl = Instance.new("TextLabel")
                    lbl.Size               = UDim2.fromScale(1, 1)
                    lbl.BackgroundTransparency = 1
                    lbl.Text               = "✕"
                    lbl.TextColor3         = Color3.fromRGB(255, 60, 60)
                    lbl.TextScaled         = true
                    lbl.Font               = Enum.Font.GothamBold
                    lbl.Parent             = bb
                end
            else
                b.Color        = Color3.fromRGB(255, 255, 255)
                b.Transparency = 0.5
                local bb = b:FindFirstChild("RemovedMarker")
                if bb then bb:Destroy() end
            end
        end
    end
end

local function getBlocksFromGhost()
    if not CloneFolder then return nil end
    local children = CloneFolder:GetChildren()
    if #children == 0 then return nil end
    local blocks = {}
    for _, b in pairs(children) do
        if (b:IsA("Part") or b:IsA("MeshPart")) and b.Name ~= "PrimaryPart" then
            -- Skip removed types
            if not removedTypes[b.Name] then
                table.insert(blocks, {
                    blockType  = b.Name,
                    cframe     = cframeToArray(b.CFrame),
                    upperBlock = false,
                })
            end
        end
    end
    return #blocks > 0 and blocks or nil
end

