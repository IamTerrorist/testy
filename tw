        end
        deactivateMovingTool()
        for _, v in pairs(CloneFolder:GetChildren()) do v:Destroy() end

        local ALLBLOCKS = ReplicatedStorage:FindFirstChild("Blocks")
        local count = 0

        for _, block in ipairs(data.blocks) do
            local cf    = arrayToCFrame(block.cframe)
            local clone = nil
            if ALLBLOCKS then
                local model = ALLBLOCKS:FindFirstChild(block.blockType)
                if model then
                    local root = model:FindFirstChild("Root")
                    if root then clone = root:Clone() end
                end
            end
            if not clone then
                clone      = Instance.new("Part")
                clone.Size = Vector3.new(3, 3, 3)
            end
            clone.Name         = block.blockType
            clone.CFrame       = cf
            clone.Anchored     = true
            clone.CanCollide   = false
            clone.Transparency = 0.5
            clone.Parent       = CloneFolder
            count = count + 1
            if count % 500 == 0 then task.wait() end
        end

        if count == 0 then notify("Empty File", "No blocks found in that file.", 3) return end
        task.wait(0.1)
        updateGhostColors()
        activateMovingTool()
