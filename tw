-- Swap minimize (-) to LEFT and close (X) to RIGHT
-- Retries until the Alexchad title bar is fully rendered
task.spawn(function()
    local function trySwap()
        -- Alexchad renders into CoreGui or PlayerGui under its own ScreenGui
        local roots = { CoreGui, LocalPlayer.PlayerGui }
        local close, minimize
        for _, root in ipairs(roots) do
            for _, gui in ipairs(root:GetChildren()) do
                for _, child in ipairs(gui:GetDescendants()) do
                    if child:IsA("TextButton") then
                        local t = child.Text
                        if t == "X" or t == "x" or t == "✕" or t == "×" or t == "✖" then
                            close = child
                        elseif t == "-" or t == "−" or t == "–" or t == "—" then
                            minimize = child
                        end
                    end
                end
            end
        end
        return close, minimize
    end

    -- Wait up to 5 seconds for the buttons to appear
    local close, minimize
    for _ = 1, 50 do
        close, minimize = trySwap()
        if close and minimize then break end
        task.wait(0.1)
    end

    if close and minimize then
        local cPos = close.Position
        local mPos = minimize.Position
        -- Force: minimize on the left (smaller X), close on the right (larger X)
        local leftX  = math.min(cPos.X.Offset, mPos.X.Offset)
        local rightX = math.max(cPos.X.Offset, mPos.X.Offset)
        local sharedY = cPos.Y
        minimize.Position = UDim2.new(cPos.X.Scale, leftX,  sharedY.Scale, sharedY.Offset)
        close.Position    = UDim2.new(cPos.X.Scale, rightX, sharedY.Scale, sharedY.Offset)
    end
end)

