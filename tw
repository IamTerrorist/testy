local function updateCorners(part)
    for _, name in ipairs({"BP_Part_R","BP_Part_L"}) do
        local old = Workspace:FindFirstChild(name)
        if old then old:Destroy() end
    end
    local pos, siz = part.Position, part.Size
    local function makeCorner(name, x, y, z, color)
        local p = Instance.new("Part")
        p.Name = name; p.Parent = Workspace
        p.Size = Vector3.new(3,3,3); p.Anchored = true
        p.Transparency = 0.3; p.CanCollide = false
        p.Position = Vector3.new(x,y,z)
        p.Color = color; p.Material = Enum.Material.Neon; p.CastShadow = false
    end
    makeCorner("BP_Part_R", pos.x+siz.x/2-1.5, pos.y+siz.y/2-1.5, pos.z+siz.z/2-1.5, Color3.new(1,0,0))
    makeCorner("BP_Part_L", pos.x-siz.x/2+1.5, pos.y-siz.y/2+1.5, pos.z-siz.z/2+1.5, Color3.new(0,0.6,1))
    local count = 0
    local ok, blks = pcall(function() return Workspace:GetPartsInPart(part) end)
    if ok then for _, b in pairs(blks) do if b.Parent and b.Parent.Name == "Blocks" then count = count + 1 end end end
    notify("Selection Updated", count.." island blocks in region", 2)
end

local function equipResizeTool(mouse)
    resizeSelBox = Instance.new("SelectionBox")
    resizeSelBox.Color            = BrickColor.Blue()
    resizeSelBox.SurfaceTransparency = 0.7
    resizeSelBox.SurfaceColor3    = Color3.fromRGB(65, 105, 225)
    resizeSelBox.Parent           = LocalPlayer.PlayerGui

    resizeHandles = Instance.new("Handles")
    resizeHandles.Color3  = Color3.fromRGB(65, 105, 225)
    resizeHandles.Style   = Enum.HandlesStyle.Resize
    resizeHandles.Faces   = Faces.new(
        Enum.NormalId.Top,    Enum.NormalId.Bottom,
        Enum.NormalId.Front,  Enum.NormalId.Back,
        Enum.NormalId.Left,   Enum.NormalId.Right
    )
    resizeHandles.Parent  = LocalPlayer.PlayerGui

    resizeHandles.MouseButton1Down:connect(function() prevResizeDist = 0 end)

    resizeHandles.MouseDrag:connect(function(normal, distance)
        if not (resizeHandles and resizeHandles.Adornee) then return end
        local delta = distance - prevResizeDist
        if math.abs(delta) < 3 then return end
        local sd = math.floor(delta/3+0.5)*3
        if sd == 0 then return end
        prevResizeDist = distance
        local adornee = resizeHandles.Adornee
        local faceVec = Vector3.FromNormalId(normal)
        local newSize = adornee.Size + Vector3.new(
            math.abs(faceVec.X)*sd,
            math.abs(faceVec.Y)*sd,
            math.abs(faceVec.Z)*sd
        )
        if newSize.X < 3 or newSize.Y < 3 or newSize.Z < 3 then return end
        adornee.Size     = newSize
        adornee.Position = adornee.Position + (faceVec * (sd/2))
        updateCorners(adornee)
    end)

    mouse.Button1Down:connect(function()
        if not (_G_ResizeTool and _G_CanReselect) then return end
        _G_CanReselect = false
        if not mouse.Target or mouse.Target.Locked then
            resizeSelBox.Adornee  = nil
            resizeHandles.Adornee = nil
            return
        end
        local target = mouse.Target
        -- Walk up to find the actual island block (clicking top face sometimes gives a child part)
        local blockTarget = target
        for _ = 1, 3 do
            if blockTarget and blockTarget.Parent and blockTarget.Parent.Name == "Blocks" then
                break
            elseif blockTarget and blockTarget.Parent then
                blockTarget = blockTarget.Parent:IsA("BasePart") and blockTarget.Parent or blockTarget
            end
        end
        -- Accept if: parent is Blocks folder, OR has Health child, OR size is 3x3x3
        local isIslandBlock = (blockTarget.Parent and blockTarget.Parent.Name == "Blocks")
            or blockTarget:FindFirstChild("Health")
            or (blockTarget.Size.X == 3 and blockTarget.Size.Y == 3 and blockTarget.Size.Z == 3)
        if isIslandBlock then
            target = blockTarget
            local oldNP = Workspace:FindFirstChild("BP_NewPart")
            if oldNP then oldNP:Destroy() end
            local NP = Instance.new("Part")
            NP.Name = "BP_NewPart"; NP.Transparency = 0.6; NP.Anchored = true
            NP.Size = target.Size; NP.Position = target.Position
            NP.CanCollide = false; NP.CastShadow = false
            NP.Material = Enum.Material.Neon; NP.Color = Color3.fromRGB(65,105,225)
            NP.Parent = Workspace
            resizeSelBox.Adornee  = NP
            resizeHandles.Adornee = NP
            updateCorners(NP)
            notify("Block Selected", "Drag the blue handles to resize your selection.", 3)
        else
            notify("Wrong Block", "Click directly on an island block.", 3)
            _G_CanReselect = true
        end
    end)
end

local function unequipResizeTool()
    if resizeSelBox  then resizeSelBox:Destroy()  resizeSelBox  = nil end
    if resizeHandles then resizeHandles:Destroy() resizeHandles = nil end
    for _, name in ipairs({"BP_NewPart","BP_Part_R","BP_Part_L"}) do
        local p = Workspace:FindFirstChild(name)
        if p then p:Destroy() end
    end
end

local function movFindCenter()
    for _, p in ipairs(CloneFolder:GetChildren()) do
        if p:IsA("Part") or p:IsA("MeshPart") then return p end
    end
    return nil
end

local function activateMovingTool()
    local mid = movFindCenter()
    if not mid then notify("Moving Tool", "No ghost blocks to move. Clone blocks first.", 3) return end
    if not CloneFolder.PrimaryPart then CloneFolder.PrimaryPart = mid end
    local target = CloneFolder.PrimaryPart
    if target and not target.Locked then
        movSelected         = target
        movOrigTransparency = movSelected.Transparency
        moveHandle.Parent   = LocalPlayer.PlayerGui
        moveHandle.Adornee  = movSelected
        movSelBox.Adornee   = movSelected
    end
end

local function deactivateMovingTool()
    movSelected        = nil
    moveHandle.Parent  = CoreGui
    moveHandle.Adornee = nil
    movSelBox.Adornee  = nil
end

moveHandle.MouseDrag:connect(function(face, distance)
    if not movSelected then return end
    local rd = math.floor(distance/3+0.5)*3
    pcall(function()
        local rs = math.round(rd/movSelected.ResizeIncrement)*movSelected.ResizeIncrement
        CloneFolder:SetPrimaryPartCFrame(movLastCFrame * CFrame.new(Vector3.FromNormalId(face)*rs))
    end)
end)
moveHandle.MouseButton1Down:connect(function()
    if movSelected then
        movLastCFrame = movSelected.CFrame
        movSelected.Transparency = movSelected.Transparency + 0.3
        movSelected.CanCollide   = false
    end
end)
moveHandle.MouseButton1Up:connect(function()
    if movSelected then movSelected.Transparency = movOrigTransparency or 0.5 end
end)

local function ensurePrimary()
    if not CloneFolder.PrimaryPart then
        local mid = movFindCenter()
        if mid then CloneFolder.PrimaryPart = mid task.wait(0.2) end
    end
end

